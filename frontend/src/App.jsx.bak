import { useState, useEffect, useRef } from 'react'
import './App.css'

const STORAGE_KEY = 'drinkWaterState';

function notify(message) {
    if (!('Notification' in window)) {
        alert(message);
        return;
    }
    if (Notification.permission === 'granted') {
        new Notification('Drink Water', { body: message });
    } else {
        alert(message);
    }
}

async function askNotificationPermission() {
    if (!('Notification' in window)) return;
    if (Notification.permission !== 'default') return;
    await Notification.requestPermission();
}

function App() {
  const [times, setTimes] = useState([])
  const [newTime, setNewTime] = useState('')
  const [message, setMessage] = useState('')
  const [lastAlert, setLastAlert] = useState('')
  const [isError, setIsError] = useState(false)

  const isFirstRender = useRef(true)

  // load
  useEffect(() => {
    const raw = localStorage.getItem(STORAGE_KEY)
    if (!raw) return
    const saved = JSON.parse(raw)
    setTimes(saved.times ?? [])
    setLastAlert(saved.lastAlert ?? '')
  }, [])

  // save
  useEffect(() => {
    if (isFirstRender.current) {
      isFirstRender.current = false
      return
    }
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ times, lastAlert }))
  }, [times, lastAlert])

  // checkTime
  useEffect(() => {
    const id = setInterval(() => {
      const currentTime = new Date
      const currentDate = currentTime.getDate()
      const currentHr = currentTime.getHours()
      const currentMin = currentTime.getMinutes()
      const HH = String(currentHr).padStart(2, '0')
      const MM = String(currentMin).padStart(2, '0')
      const fullTime = HH + ':' + MM
      const stamp = String(currentDate) + ',' + fullTime

      if (times.includes(fullTime) && lastAlert !== stamp) {
        notify('Time to drink water~')
        setLastAlert(stamp)
      }
    }, 1000)

    return () => clearInterval(id)
  }, [times, lastAlert])

  function addTime() {
    if (!newTime) {
      setMessage('Please select a time first')
      setIsError(true)
      return
    }
    if (times.includes(newTime)) {
      setMessage('This time has already been added')
      setIsError(true)
      return
    }
    setTimes([...times, newTime].sort())
    setMessage('')
    setIsError(false)
    askNotificationPermission()
  }

  function deleteTime(t) {
    setTimes(times.filter(x => x !== t))
  }

  return (
    <div>
      <h1>Drink Water</h1>

      <label htmlFor="input">Set your timer:</label>
      <input 
        type="time" 
        id="input" 
        value={newTime}
        onChange={e => setNewTime(e.target.value)}
      />
      <button id="addButton" onClick={addTime}>Add</button>

      <ul id="timeList">
        {times.map(t => (
          <li key={t}>
            {t} 
            <button onClick={() => deleteTime(t)}>×</button>
            </li>
        ))}
      </ul>

      <p id="statusText" className={isError ? 'error' : ''}>{message}</p>
    </div>
  )
}

export default App
